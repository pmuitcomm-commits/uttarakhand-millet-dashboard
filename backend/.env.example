# Security Configuration - MUST be set for production
SECRET_KEY=generate-a-secure-random-key-at-least-32-characters-use-secrets.token_urlsafe

# Database Configuration - Choose ONE method:
# METHOD 1: Full DATABASE_URL
DATABASE_URL=postgresql://username:password@localhost:5432/millet_db

# METHOD 2: Individual variables (if DATABASE_URL not set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=millet_db
DB_USER=millet_user
DB_PASSWORD=secure_password

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# JWT Configuration
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Rate Limiting
# Global rate limit: 60 requests per minute per IP
# Adjust in main.py if needed
